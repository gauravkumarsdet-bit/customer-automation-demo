pipeline {
    agent any

    environment {
        APP_PORT = '8080'
        APP_DIR = 'app'
        AUTOMATION_DIR = 'bdd-automation'
        JAVA_EXE = 'C:\\Program Files\\Java\\jdk-24\\bin\\java.exe'
        MAVEN_CMD = 'C:\\Users\\sohinee\\apache-maven-3.9.10-bin\\apache-maven-3.9.10\\bin\\mvn.cmd'
        PYTHON_EXE = 'C:\\Users\\gaura\\AppData\\Local\\Programs\\Python\\Python314\\python.exe'
        ALLURE_CMD = 'C:\\Users\\gaura\\AppData\\Roaming\\npm\\allure.cmd'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Tools') {
            steps {
                bat '''
                    "%JAVA_EXE%" -version
                    "%MAVEN_CMD%" -version
                    "%PYTHON_EXE%" --version
                    "%ALLURE_CMD%" --version
                '''
            }
        }

        stage('Start Spring Boot App') {
            steps {
                powershell '''
                Write-Host "Starting Spring Boot app..."

                $appPath = Join-Path $env:WORKSPACE $env:APP_DIR
                $logFile = Join-Path $env:WORKSPACE "springboot-app.log"
                $pidFile = Join-Path $env:WORKSPACE "springboot-app.pid"

                if (Test-Path $logFile) {
                    Remove-Item $logFile -Force
                }

                $job = Start-Job -ScriptBlock {
                    param($mavenCmd, $appPath, $logFile)
                    Set-Location $appPath
                    & $mavenCmd spring-boot:run *> $logFile
                } -ArgumentList $env:MAVEN_CMD, $appPath, $logFile

                $job.Id | Out-File $pidFile

                Write-Host "Spring Boot background job ID: $($job.Id)"
                Start-Sleep -Seconds 30
                '''
            }
        }

        stage('Check App Health') {
            steps {
                powershell '''
                $url = "http://localhost:$env:APP_PORT/api/employees"

                Write-Host "Checking app health at $url"

                for ($i = 1; $i -le 12; $i++) {
                    try {
                        $response = Invoke-WebRequest -Uri $url -UseBasicParsing
                        if ($response.StatusCode -eq 200) {
                            Write-Host "Application is up."
                            exit 0
                        }
                    } catch {
                        Write-Host "Attempt ${i}: App not ready yet..."
                        Start-Sleep -Seconds 5
                    }
                }

                Write-Error "Application did not start successfully."
                exit 1
                '''
            }
        }

        stage('Setup Python Environment') {
            steps {
                 powershell '''
                cd $env:AUTOMATION_DIR

                if (Test-Path "venv") {
                    Remove-Item -Recurse -Force "venv"
                }

                & $env:PYTHON_EXE -m venv venv
                .\\venv\\Scripts\\python.exe -m pip install --upgrade pip
                .\\venv\\Scripts\\pip.exe install -r requirements.txt
                '''
            }
        }

        stage('Run Behave Tests') {
            steps {
                powershell '''
                cd $env:AUTOMATION_DIR

                if (Test-Path "reports/allure-results") {
                    Remove-Item -Recurse -Force "reports/allure-results"
                }

                New-Item -ItemType Directory -Force -Path "reports/allure-results"

                .\\venv\\Scripts\\behave.exe -f allure_behave.formatter:AllureFormatter -o reports/allure-results
                '''
            }
        }
    }

    post {
        always {
            powershell '''
            Write-Host "Stopping Spring Boot app..."

            $pidFile = Join-Path $env:WORKSPACE "springboot-app.pid"

            if (Test-Path $pidFile) {
                $jobId = Get-Content $pidFile
                Stop-Job -Id $jobId -ErrorAction SilentlyContinue
                Remove-Job -Id $jobId -Force -ErrorAction SilentlyContinue
                Remove-Item $pidFile -Force
            }

            $appLog = Join-Path $env:WORKSPACE "springboot-app.log"
            if (Test-Path $appLog) {
                Write-Host "Spring Boot log:"
                Get-Content $appLog -Tail 80
            }
            '''

            archiveArtifacts artifacts: 'bdd-automation/reports/allure-results/**', allowEmptyArchive: true
            archiveArtifacts artifacts: 'bdd-automation/reports/allure-reports/**/*.html', allowEmptyArchive: true
            archiveArtifacts artifacts: 'springboot-app.log', allowEmptyArchive: true
        }
    }
}